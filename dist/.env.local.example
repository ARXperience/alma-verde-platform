# =====================================================
# ALMA VERDE PLATFORM - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env.local and fill in your actual values

# =====================================================
# SUPABASE
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# GOOGLE GEMINI API
# =====================================================
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# =====================================================
# BOLD (PAYMENTS)
# =====================================================
BOLD_API_KEY=your-bold-api-key-here
BOLD_SECRET_KEY=your-bold-secret-key-here
BOLD_WEBHOOK_SECRET=your-bold-webhook-secret-here
NEXT_PUBLIC_BOLD_ENVIRONMENT=sandbox # or 'production'

# =====================================================
# FACTURACIÓN ELECTRÓNICA (DIAN)
# =====================================================
# Choose your provider: alegra, siigo, etc.
INVOICING_PROVIDER=alegra
INVOICING_API_KEY=your-invoicing-api-key-here
INVOICING_API_SECRET=your-invoicing-api-secret-here

# =====================================================
# APP CONFIGURATION
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Alma Verde Platform

# =====================================================
# EMAIL (Optional - for transactional emails)
# =====================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@almaverde.co
